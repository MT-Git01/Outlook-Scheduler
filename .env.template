# Microsoft Entra ID (M365) Configurations
CLIENT_ID=your_microsoft_client_id
CLIENT_SECRET=your_microsoft_client_secret
TENANT_ID=common
REDIRECT_URI=http://localhost:8501

# Application Configurations
# APPROVER_EMAIL: comma-separated list of authorized approver emails
APPROVER_EMAIL=approver1@yourcompany.com,approver2@yourcompany.com
ENCRYPTION_KEY=your_fernet_encryption_key_base64
# LOG_LEVEL: WARNING (production) | INFO or DEBUG (local development only)
LOG_LEVEL=INFO

# Database Mode (Set to true to skip Datastore initialization and use local SQLite)
USE_LOCAL_MOCK_DB=true
SQLITE_DB_PATH=local_database.db
